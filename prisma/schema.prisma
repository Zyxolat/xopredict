generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum RoundType {
  arena
  solo
}

enum CosmeticType {
  card_back
  flip_fx
  frame
}

model Player {
  id                 String          @id @default(uuid())
  userId             String?         @unique
  user               User?           @relation(fields: [userId], references: [id], onDelete: SetNull)
  address            String?         @unique
  email              String?         @unique
  username           String?         @unique
  totalWonUsdm       Decimal         @default(0) @db.Decimal(36, 18)
  totalPlayed        Int             @default(0)
  dailyBetTotalUsdm  Decimal         @default(0) @db.Decimal(36, 18)
  lastBetDate        DateTime        @default(now()) @db.Date
  rank               String          @default("Bronze")
  onboarded          Boolean         @default(false)
  isBanned           Boolean         @default(false)
  streakDays         Int             @default(0)
  lastFreePlay       DateTime?
  vipExpiresAt       DateTime?       // VIP pass expiration; null = not VIP
  createdAt          DateTime        @default(now())
  picks              Pick[]
  seasonXp           SeasonXp[]
  cosmetics          CosmeticOwned[]
  referralsMade      Referral[]      @relation("referrer")
  referralReceived   Referral?       @relation("referee")
  arenasCreated      PrivateArena[]
  @@map("players")
}

model Round {
  id            String    @id @default(uuid())
  roundId       BigInt    @unique
  type          RoundType
  commitHash    String
  serverSeed    String?
  clientSeed    String?
  nonce         Int?
  vrfRandom     String?
  numbers       Int[]
  winnerAddress String?
  potUsdm       Decimal?  @db.Decimal(36, 18)
  txHash        String?
  vrfRequestId  String?
  status        String    @default("pending")
  createdAt     DateTime  @default(now())
  picks         Pick[]
  @@map("rounds")
}

model Pick {
  id        String @id @default(uuid())
  roundId   String
  playerId  String
  cardIndex Int
  value     Int?
  round     Round  @relation(fields: [roundId], references: [id], onDelete: Cascade)
  player    Player @relation(fields: [playerId], references: [id])
  @@map("picks")
}

model Referral {
  id         String   @id @default(uuid())
  referrerId String
  refereeId  String   @unique
  bonusClaimed Boolean @default(false)
  createdAt  DateTime @default(now())
  referrer   Player   @relation("referrer", fields: [referrerId], references: [id])
  referee    Player   @relation("referee", fields: [refereeId], references: [id])
  @@map("referrals")
}

model Season {
  id        String     @id @default(uuid())
  name      String
  startDate DateTime
  endDate   DateTime
  isActive  Boolean    @default(true)
  xp        SeasonXp[]
  @@map("seasons")
}

model SeasonXp {
  id       String @id @default(uuid())
  playerId String
  seasonId String
  xp       Int    @default(0)
  player   Player @relation(fields: [playerId], references: [id])
  season   Season @relation(fields: [seasonId], references: [id])
  @@unique([playerId, seasonId])
  @@map("season_xp")
}

model CosmeticOwned {
  id          String       @id @default(uuid())
  playerId    String
  type        CosmeticType
  name        String
  purchasedAt DateTime     @default(now())
  player      Player       @relation(fields: [playerId], references: [id])
  @@map("cosmetics_owned")
}

model PrivateArena {
  id          String   @id @default(uuid())
  creatorId   String
  inviteCode  String   @unique
  betAmount   Decimal  @db.Decimal(36, 18)
  maxPlayers  Int
  currentPlayers Int   @default(1)
  status      String   @default("active") // active, full, completed
  playerIds   String[] // array of player IDs (UUIDs)
  createdAt   DateTime @default(now())
  expiresAt   DateTime // 30 min timeout
  creator     Player   @relation(fields: [creatorId], references: [id])
  @@map("private_arenas")
}

// NextAuth Models
model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  accounts      Account[]
  sessions      Session[]
  player        Player?
  @@map("users")
}

model Account {
  id                 String  @id @default(cuid())
  userId             String
  type               String
  provider           String
  providerAccountId  String
  refresh_token      String?  @db.Text
  access_token       String?  @db.Text
  expires_at         Int?
  token_type         String?
  scope              String?
  id_token           String?  @db.Text
  session_state      String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}
